{
  "name": "@paulirish/chromestatus",
  "version": "0.1.0",
  "type": "module",
  "description": "Modern, idiomatic client interface for ChromeStatus feature data",
  "exports": {
    ".": "./src/index.ts",
    "./data/*": "./data/*"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "fetch": "node build/fetch.ts",
    "preflight": "pnpm test",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run test:node",
    "test:node": "node --test test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "web-features": "^3.27.0"
  }
}
