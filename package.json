{
  "name": "@paulirish/chromestatus",
  "version": "0.1.9",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "description": "Modern, idiomatic client interface for ChromeStatus feature data",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulirish/chromestatus.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./data/*": "./data/*"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "audit:mappings": "node scripts/print-join-table.ts",
    "audit:ot-symbols": "node scripts/print-active-ot-symbols.ts",
    "compile": "node build/compile-data.ts",
    "download": "node build/download-raw.ts",
    "fetch": "pnpm run download && pnpm run compile",
    "preflight": "pnpm test",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run typecheck && pnpm run test:node",
    "test:node": "node --test test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "web-features": "^3.27.0"
  }
}
